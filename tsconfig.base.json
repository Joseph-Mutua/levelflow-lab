{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@levelflow/mock-data": ["packages/mock-data/src/index.ts"],
      "@levelflow/workflow-engine": ["packages/workflow-engine/src/index.ts"],
      "@levelflow/graphql-schema": ["packages/graphql-schema/src/index.ts"],
      "@levelflow/ui": ["packages/ui/src/index.ts"]
    }
  }
}
